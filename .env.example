# ================================================================
#  KASIRA POS — Environment Variables
#  Copy file ini ke .env lalu isi nilai yang diperlukan:
#    cp .env.example .env
# ================================================================

# ── Database (PostgreSQL) ────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_USER=kasira
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=kasira_db
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=ganti_dengan_hex_32_byte_random

# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ganti_dengan_fernet_key

# ── CORS ─────────────────────────────────────────────────────────
# Ganti IP_VPS dengan IP public server kamu
BACKEND_CORS_ORIGINS=["http://IP_VPS:3000","http://localhost:3000"]

# ── Frontend ─────────────────────────────────────────────────────
# URL yang bisa dijangkau dari browser user
NEXT_PUBLIC_API_URL=http://IP_VPS:8000/api/v1

# ── WhatsApp OTP — Fonnte ─────────────────────────────────────────
# Daftar di https://fonnte.com — ambil token dari dashboard
FONNTE_TOKEN=

# ── Payment — Xendit xenPlatform ─────────────────────────────────
# Master API Key dari dashboard Xendit
XENDIT_API_KEY=
# Webhook token dari Xendit dashboard
XENDIT_WEBHOOK_TOKEN=
# Set True saat production
XENDIT_IS_PRODUCTION=False

# ── App ──────────────────────────────────────────────────────────
ENVIRONMENT=production
