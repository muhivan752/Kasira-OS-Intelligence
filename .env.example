# ================================================================
#  KASIRA POS — Environment Variables
#  Copy file ini ke .env lalu isi nilai yang diperlukan:
#    cp .env.example .env
# ================================================================

# ── Database (PostgreSQL) ────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_USER=kasira
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=kasira_db
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=ganti_dengan_hex_32_byte_random

# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ganti_dengan_fernet_key

# ── CORS ─────────────────────────────────────────────────────────
# Ganti IP_VPS dengan IP public server kamu
BACKEND_CORS_ORIGINS=["http://IP_VPS:3000","http://localhost:3000"]

# ── Frontend ─────────────────────────────────────────────────────
# URL yang bisa dijangkau dari browser user
NEXT_PUBLIC_API_URL=http://IP_VPS:8000/api/v1

# ── WhatsApp OTP — Fonnte ─────────────────────────────────────────
# Daftar di https://fonnte.com — ambil token dari dashboard
FONNTE_TOKEN=

# ── Payment — Xendit xenPlatform ─────────────────────────────────
# Master API Key dari dashboard Xendit
XENDIT_API_KEY=
# Webhook token dari Xendit dashboard
XENDIT_WEBHOOK_TOKEN=
# Set True saat production
XENDIT_IS_PRODUCTION=False

# ── App ──────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Claude AI (untuk AI Chatbot Owner — Feature C) ───────────────
# Ambil di https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentry Error Tracking ─────────────────────────────────────────
# Buat project di https://sentry.io → Settings → Client Keys → DSN
# Backend FastAPI + Next.js pakai DSN yang sama
SENTRY_DSN=https://...@sentry.io/...
# Untuk Next.js (harus prefix NEXT_PUBLIC_ agar bisa dibaca browser)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Cloudflare R2 (APK hosting + backup) ─────────────────────────
# Buat bucket di Cloudflare R2 → Settings → API Tokens → R2 Token
# Dipakai oleh build-apk.yml untuk upload APK (tidak perlu di VPS)
# R2_ACCOUNT_ID=abc123def456...          # Cloudflare Account ID
# R2_ACCESS_KEY_ID=...                   # R2 Token → Access Key ID
# R2_SECRET_ACCESS_KEY=...              # R2 Token → Secret Access Key
# R2_BUCKET=kasira-apk                  # Nama bucket R2
# R2_PUBLIC_URL=https://pub-xxx.r2.dev  # Custom domain atau R2.dev public URL
# (Catatan: R2 credentials ini masuk ke GitHub Secrets, BUKAN ke .env VPS)
